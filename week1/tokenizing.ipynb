   "source": [
    "### Tokenizing with code"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "05d3a877",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[13225, 11, 1495, 553, 481, 30]\n"
     ]
    }
   ],
   "source": [
    "import tiktoken\n",
    "encoding = tiktoken.encoding_for_model(\"gpt-4.1-mini\")   \n",
    "tokens = encoding.encode(\"Hello, how are you?\")\n",
    "print(tokens)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c57a5239",
   "metadata": {},
   "source": []
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "c871c0fa",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Token ID: 13225, Token: Hello\n",
      "Token ID: 11, Token: ,\n",
      "Token ID: 1495, Token:  how\n",
      "Token ID: 553, Token:  are\n",
      "Token ID: 481, Token:  you\n",
      "Token ID: 30, Token: ?\n"
     ]
    }
   ],
   "source": [
    "for token_id in tokens:\n",
    "    print(f\"Token ID: {token_id}, Token: {encoding.decode([token_id])}\")"
   ]
  },
